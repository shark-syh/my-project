<section class="profile-hero animate-in delay-1">
  <img class="profile-avatar" src="<%- url_for(page.avatar) %>" alt="<%= page.name %>头像" decoding="async">
  <div>
    <a class="back-link" href="<%- url_for('/members/') %>">返回成员荣誉墙</a>
    <p class="eyebrow"><%= page.role %> · <%= page.grade %></p>
    <h1><%= page.name %></h1>
    <p class="profile-summary"><%= page.summary %></p>
  </div>
</section>

<section class="profile-layout">
  <article class="profile-section animate-in delay-2">
    <h2>代表荣誉</h2>
    <% if ((page.honors || []).length) { %>
    <ul class="honor-list">
      <% page.honors.forEach((honor) => { %>
        <li><%= honor %></li>
      <% }) %>
    </ul>
    <% } else { %>
    <p class="empty-hint">暂无荣誉记录</p>
    <% } %>
  </article>

  <aside class="profile-section accent animate-in delay-3">
    <h2>项目方向</h2>
    <% if ((page.projects || []).length) { %>
    <ul class="project-list">
      <% page.projects.forEach((project) => { %>
        <li><%= project %></li>
      <% }) %>
    </ul>
    <% } else { %>
    <p class="empty-hint">暂无项目记录</p>
    <% } %>
    <% if (page.quote) { %><blockquote><%= page.quote %></blockquote><% } %>
  </aside>
</section>
