<section class="page-hero animate-in delay-1">
  <h1>竞赛时间线</h1>
  <p class="sub">记录每一段探索的足迹，见证每一次成长的跃迁</p>
  <button class="timeline-add-btn" id="timelineAddBtn" onclick="window.__timelineEditor && window.__timelineEditor.showEditor()" aria-label="添加比赛">+ 添加比赛</button>
</section>

<section class="timeline-section">
  <div class="timeline">
    <% page.groups.forEach(function (group) { %>
    <div class="timeline-group">
      <div class="timeline-year"><span><%= group.year %></span></div>
      <% group.items.forEach(function (ev, idx) { %>
      <div class="timeline-item dot-<%= ev.level %> animate-in delay-<%= Math.min(idx + 1, 5) %>"
           <%- ev.manual && ev.id ? 'data-manual-id="' + ev.id + '"' : '' %>>
        <div class="timeline-dot"></div>
        <div class="timeline-card">
          <% if (ev.manual) { %>
          <div class="timeline-card-actions for-edit">
            <button class="timeline-card-action-btn" title="编辑" data-action="edit-<%= ev.id %>" aria-label="编辑比赛">&#9998;</button>
            <button class="timeline-card-action-btn delete" title="删除" data-action="delete-<%= ev.id %>" aria-label="删除比赛">&#10005;</button>
          </div>
          <% } %>
          <div class="card-date"><%= group.year %></div>
          <h3><%= ev.title %></h3>
          <div class="card-meta">
            <% if (ev.member) { %>
              <span class="card-member"><%= ev.member %></span>
              <span><%= ev.role %></span>
            <% } else { %>
              <span class="timeline-manual-badge">手动添加</span>
            <% } %>
            <span class="card-level <%= ev.level %>"><%= ev.label %></span>
          </div>
        </div>
      </div>
      <% }); %>
    </div>
    <% }); %>
  </div>
</section>

<!-- 编辑浮层 -->
<div class="timeline-editor-overlay" id="timelineEditorOverlay">
  <div class="timeline-editor-panel">
    <h3 id="timelineEditorTitle">添加比赛</h3>
    <div class="timeline-editor-form">
      <div class="editor-form-field">
        <label for="timelineEditYear">年份</label>
        <input type="number" id="timelineEditYear" min="2000" max="2099" placeholder="例如 2025">
      </div>
      <div class="editor-form-field">
        <label for="timelineEditLevel">级别</label>
        <select id="timelineEditLevel">
          <option value="school">校级</option>
          <option value="city">市级</option>
          <option value="provincial">省级</option>
          <option value="national">国家级</option>
          <option value="international">国际级</option>
        </select>
      </div>
      <div class="editor-form-field">
        <label for="timelineEditTitle">比赛名称</label>
        <input type="text" id="timelineEditTitle" placeholder="例如 全国青少年科技创新大赛">
      </div>
      <div class="timeline-editor-btns">
        <button class="editor-btn editor-btn-cancel" onclick="window.__timelineEditor && window.__timelineEditor.hideEditor()">取消</button>
        <button class="editor-btn editor-btn-primary" id="timelineSaveBtn">保存</button>
      </div>
    </div>
  </div>
</div>
