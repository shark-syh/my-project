<%
const members = site.data.members || [];
const overrides = site.data['home-stats'] || {};

// 自动计算
const autoMembers = members.length;
let autoHonors = 0;
let autoProjects = 0;
let minYear = Infinity;
let maxYear = 0;
members.forEach((m) => {
  autoHonors += (m.honors || []).length;
  autoProjects += (m.projects || []).length;
  (m.honors || []).forEach((h) => {
    const ym = h.match(/^(\d{4})\s*年/);
    if (ym) {
      const y = parseInt(ym[1]);
      if (y < minYear) minYear = y;
      if (y > maxYear) maxYear = y;
    }
  });
});
const autoYearSpan = minYear < Infinity ? (maxYear === minYear ? String(minYear) : minYear + '–' + maxYear) : '–';

// 覆盖优先
function val(key, auto) {
  const ov = overrides[key];
  return (ov !== null && ov !== undefined) ? String(ov) : String(auto);
}
const display = {
  members: val('members', autoMembers),
  honors: val('honors', autoHonors),
  projects: val('projects', autoProjects),
  yearSpan: val('yearSpan', autoYearSpan)
};
%>
<section class="hero" id="top">
  <div class="hero-copy animate-in delay-1">
    <img class="hero-logo" src="<%- url_for('/assets/images/logo.webp') %>" alt="贵阳二中科技先锋队 Logo" decoding="async">
    <p class="eyebrow">Guiyang No.2 High School</p>
    <h1>贵阳二中科技先锋队</h1>
    <p class="intro">
      下属有数十个科技社团，一支由学生发起并壮大的队伍。在学校领导和老师的关怀下，长期开展与科技相关的各种科技实践活动。学校的创客空间优先向本社团的同学无偿开放，让同学们可以在科技的海洋里体验畅游，并有机会参加市级、省级、国家级乃至世界级的各种比赛。
    </p>
    <div class="hero-actions">
      <a class="button primary" href="<%- url_for('/members/') %>">查看荣誉墙</a>
      <a class="button secondary" href="<%- url_for('/gallery/') %>">浏览照片墙</a>
      <a class="button secondary" href="#team">认识成员</a>
    </div>
  </div>
  <div class="hero-stats animate-in delay-3" id="heroStats" aria-label="队伍速览">
    <div class="hero-stat" data-key="members" data-auto="<%= autoMembers %>">
      <span class="hero-stat-number"><%= display.members %></span>
      <span class="hero-stat-label">技术力量</span>
    </div>
    <div class="hero-stat-divider"></div>
    <div class="hero-stat" data-key="honors" data-auto="<%= autoHonors %>">
      <span class="hero-stat-number"><%= display.honors %></span>
      <span class="hero-stat-label">赛事战绩</span>
    </div>
    <div class="hero-stat-divider"></div>
    <div class="hero-stat" data-key="projects" data-auto="<%= autoProjects %>">
      <span class="hero-stat-number"><%= display.projects %></span>
      <span class="hero-stat-label">工程落地</span>
    </div>
  </div>
</section>

<section class="section" id="team">
  <div class="section-heading animate-in delay-1">
    <p class="eyebrow">Members & Honor Wall</p>
    <h2>成员与荣誉</h2>
    <p>聚是一团火，散是满天星。</p>
  </div>
  <div class="member-grid">
    <% members.forEach((member, idx) => { %>
      <a class="member-card animate-in delay-<%= Math.min(idx + 1, 5) %>" href="<%- url_for('/members/' + member.slug + '/') %>">
        <img class="member-avatar" src="<%- url_for(member.avatar) %>" alt="<%= member.name %>头像" loading="lazy" decoding="async">
        <div class="member-content">
          <p class="member-role"><%= member.role %></p>
          <h3><%= member.name %></h3>
          <ul class="honor-list compact">
            <% (member.honors || []).slice(0, 2).forEach((honor) => { %>
              <li><%= honor %></li>
            <% }) %>
          </ul>
          <span class="text-link">进入个人页</span>
        </div>
      </a>
    <% }) %>
  </div>
</section>

<section class="section band">
  <div class="section-heading animate-in delay-1">
    <p class="eyebrow">Maker Space</p>
    <h2>从兴趣到作品</h2>
    <p>技术拯救世界。 Tech saves the world.</p>
  </div>
</section>
<%- js('js/members-editor') %>

<script>
(function () {
  if (!window.__admin) return;

  function initStatsEditor() {
    var loggedIn = window.__admin.isLoggedIn();
    var token = window.__admin.getToken();
    var statsEl = document.getElementById('heroStats');
    if (!statsEl) return;

    var numbers = statsEl.querySelectorAll('.hero-stat-number');
    numbers.forEach(function (numEl) {
      var statEl = numEl.parentElement;
      var key = statEl.getAttribute('data-key');
      var autoVal = statEl.getAttribute('data-auto');

      if (loggedIn) {
        statEl.classList.add('editable');
        numEl.title = '点击编辑 · 双击重置为自动值（' + autoVal + '）';
        numEl.style.cursor = 'pointer';

        // 点击 → 编辑
        numEl.addEventListener('click', function (e) {
          e.stopPropagation();
          if (numEl.querySelector('input')) return;
          var current = numEl.textContent.trim();
          var input = document.createElement('input');
          input.type = 'text';
          input.className = 'hero-stat-input';
          input.value = current;
          input.style.cssText = numEl.style.cssText;
          numEl.textContent = '';
          numEl.appendChild(input);
          input.focus();
          input.select();

          function save() {
            var val = input.value.trim();
            if (!val) { cancel(); return; }
            fetch('/api/home-stats', {
              method: 'PUT',
              headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
              body: JSON.stringify({ key: key, value: val })
            }).then(function (r) {
              if (r.ok) {
                numEl.textContent = val;
              } else {
                cancel();
              }
            }).catch(function () { cancel(); });
          }

          function cancel() {
            numEl.textContent = current;
          }

          input.addEventListener('blur', save);
          input.addEventListener('keydown', function (ev) {
            if (ev.key === 'Enter') { input.blur(); }
            if (ev.key === 'Escape') { cancel(); }
          });
        });

        // 双击 → 重置为自动
        numEl.addEventListener('dblclick', function (e) {
          e.stopPropagation();
          if (numEl.querySelector('input')) return;
          if (!confirm('重置「' + key + '」为自动计算值（' + autoVal + '）？')) return;
          fetch('/api/home-stats', {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
            body: JSON.stringify({ key: key })
          }).then(function (r) {
            if (r.ok) {
              numEl.textContent = autoVal;
            }
          });
        });
      } else {
        statEl.classList.remove('editable');
        numEl.title = '';
        numEl.style.cursor = '';
      }
    });
  }

  initStatsEditor();
  window.addEventListener('admin-auth-change', function () {
    initStatsEditor();
  });
})();
</script>
